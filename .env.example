# BrandBridge — 環境変数（コピー用）

# --- 必須 ---
# Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- 本番・ベータで推奨（OG / sitemap / canonical）---
# 末尾スラッシュなし。Vercel 本番ドメインまたはカスタムドメイン
NEXT_PUBLIC_SITE_URL=https://your-domain.example

# 注意:
# - service_role キーはアプリに設定しない（本プロジェクト未使用）
# - .env.local は gitignore 済み。実キーをコミットしないこと
# - 詳細: docs/ENV.md
