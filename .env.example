# BrandBridge — 環境変数（コピー用）

# --- 必須 ---
# Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- 本番・ベータで推奨（OG / sitemap / canonical）---
# 末尾スラッシュなし。Vercel 本番ドメインまたはカスタムドメイン
NEXT_PUBLIC_SITE_URL=https://your-domain.example

# 一時的にエラー詳細（message / stack）を画面表示（本番調査用。調査後は削除推奨）
# NEXT_PUBLIC_SHOW_ERROR_DETAILS=true

# ベータ運用: true のとき新規案件のみ review_status=approved で作成
# 管理者審査を使う場合は false（pending_review で /admin/cases に出る）
BETA_AUTO_APPROVE_CASES=false

# --- サーバー専用（NEXT_PUBLIC にしない）---
# Supabase → Project Settings → API → service_role
# /cases の応募件数集計（RLS を超えた集計読取）と admin:create で使用
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# ADMIN_EMAIL=admin@yourdomain.com
# ADMIN_PASSWORD=ChangeMe_StrongPass_8chars
# 実行: npm run admin:create

# お問い合わせ通知・管理画面からの返信（Resend）※必須（サーバー専用）
# .env.local と Vercel Environment Variables（Production / Preview）の両方に設定
RESEND_API_KEY=re_xxxxxxxx
CONTACT_RECEIVE_EMAIL=you@example.com
# 未登録企業向け営業メール（/admin/mail）— From と Reply-To は同一営業アドレス推奨
# 例: BrandBridge <sales@brandbridge.jp> / REPLY_TO_EMAIL=sales@brandbridge.jp
MAIL_FROM_NAME=BrandBridge
MAIL_FROM_ADDRESS=sales@brandbridge.jp
REPLY_TO_EMAIL=sales@brandbridge.jp
# Resend 受信: Dashboard → Webhooks → email.received → /api/resend/inbound
# （受信ドメインを MAIL_FROM_ADDRESS に設定）
# CONTACT 通知の From は当面 onboarding@resend.dev（lib/sendContactEmail.ts）

# 注意:
# - service_role はサーバーのみ。ブラウザ / NEXT_PUBLIC_* に入れない
# - .env.local は gitignore 済み。実キーをコミットしないこと
# - 詳細: docs/ENV.md / docs/ADMIN_SETUP.md
