# BrandBridge — 環境変数（コピー用）

# --- 必須 ---
# Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- 本番・ベータで推奨（OG / sitemap / canonical）---
# 末尾スラッシュなし。Vercel 本番ドメインまたはカスタムドメイン
NEXT_PUBLIC_SITE_URL=https://your-domain.example

# 一時的にエラー詳細（message / stack）を画面表示（本番調査用。調査後は削除推奨）
# NEXT_PUBLIC_SHOW_ERROR_DETAILS=true

# ベータ運用: true のとき新規案件のみ review_status=approved で作成
# 管理者審査を使う場合は false（pending_review で /admin/cases に出る）
BETA_AUTO_APPROVE_CASES=false

# --- サーバー専用（NEXT_PUBLIC にしない）---
# Supabase → Project Settings → API → service_role
# /cases の応募件数集計（RLS を超えた集計読取）と admin:create で使用
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# ADMIN_EMAIL=admin@yourdomain.com
# ADMIN_PASSWORD=ChangeMe_StrongPass_8chars
# 実行: npm run admin:create

# 注意:
# - service_role はサーバーのみ。ブラウザ / NEXT_PUBLIC_* に入れない
# - .env.local は gitignore 済み。実キーをコミットしないこと
# - 詳細: docs/ENV.md / docs/ADMIN_SETUP.md
